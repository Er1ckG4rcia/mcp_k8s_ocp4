{
  "name": "mcp-ocp-observer",
  "version": "1.0.0",
  "description": "MCP server for OpenShift cluster observability and troubleshooting",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --external:@kubernetes/client-node --external:express --external:@modelcontextprotocol/sdk --external:zod --packages=external --format=esm",
    "typecheck": "node --max-old-space-size=4096 node_modules/.bin/tsc --noEmit || true",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@kubernetes/client-node": "0.21.0",
    "@modelcontextprotocol/sdk": "1.10.2",
    "express": "4.21.2",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "22.10.0",
    "esbuild": "0.24.2",
    "tsx": "4.19.0",
    "typescript": "5.7.2"
  }
}
